# Base URL for the GodsPeoples backend API.
# Relative path so dev requests go through the Vite proxy (see vite.config.js),
# which forwards /api -> http://localhost:4000 and avoids CORS in dev.
# For a deployed build, set this to the full API origin, e.g.
# https://api.godspeoples.example/api/v1
VITE_API_BASE_URL=/api/v1
